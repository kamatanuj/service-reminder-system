# Service Reminder System
NODE_ENV=development

# Server Port (⚠️ Use 3001+ to avoid conflicts with other services)
PORT=3001

# MongoDB
MONGODB_URI=mongodb://localhost:27017/garage_service

# ==========================================
# GOOGLE CALENDAR - GARAGE OWNER SETUP
# ==========================================
# Step 1: Go to /admin/setup-calendar to get OWNER_REFRESH_TOKEN
# Step 2: Add it below after OAuth authorization

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Owner's refresh token (from /admin/setup-calendar)
OWNER_REFRESH_TOKEN=your_owner_refresh_token_here

# Owner's calendar ID (usually 'primary')
OWNER_CALENDAR_ID=primary

# Garage owner email (for calendar invites)
OWNER_EMAIL=owner@yourgarage.com

# Garage info
GARAGE_NAME=Your Garage Name
GARAGE_ADDRESS=123 Main St, City, Country

# ==========================================
# EMAIL (SendGrid)
# ==========================================
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=noreply@yourgarage.com
FROM_NAME=Your Garage Name

# ==========================================
# BASE URL
# ==========================================
BASE_URL=http://localhost:3001

# ==========================================
# ADMIN
# ==========================================
ADMIN_API_KEY=your_secure_admin_key